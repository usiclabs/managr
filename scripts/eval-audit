#!/usr/bin/env bash
# eval-audit — audit eval coverage across all skills
#
# Usage:
#   ./scripts/eval-audit              # coverage report for enabled skills
#   ./scripts/eval-audit --all        # include disabled skills
#   ./scripts/eval-audit --stubs      # generate stub eval entries for uncovered skills
#   ./scripts/eval-audit --json       # machine-readable JSON output
#
# Output: eval coverage stats — which skills have eval specs, which don't, inferred output patterns.
# Used by: skill-evals, skill-health, self-review, tool-builder.
# Dependencies: jq, grep, bash 4+

set -euo pipefail

SCRIPT_DIR="$(cd "$(dirname "$0")/.." && pwd)"
EVALS_FILE="${SCRIPT_DIR}/skills/skill-evals/evals.json"
AEON_YML="${SCRIPT_DIR}/aeon.yml"
SKILLS_DIR="${SCRIPT_DIR}/skills"

SHOW_ALL=false
GENERATE_STUBS=false
FORMAT="text"

while [[ $# -gt 0 ]]; do
  case "$1" in
    --all) SHOW_ALL=true; shift ;;
    --stubs) GENERATE_STUBS=true; shift ;;
    --json) FORMAT="json"; shift ;;
    -h|--help)
      sed -n '2,8p' "$0" | sed 's/^# \?//'
      exit 0
      ;;
    *) echo "Unknown arg: $1"; exit 1 ;;
  esac
done

# --- Parse evals.json for covered skills ---
if [ ! -f "$EVALS_FILE" ]; then
  echo "ERROR: evals.json not found at ${EVALS_FILE}" >&2
  exit 1
fi

COVERED_SKILLS=$(jq -r '.skills | keys[]' "$EVALS_FILE" 2>/dev/null)

# --- Parse aeon.yml for registered skills and their enabled status ---
# Extract skill entries: lines like "  skill-name: { enabled: true/false, ... }"
declare -A SKILL_ENABLED
while IFS= read -r line; do
  skill=$(echo "$line" | sed -n 's/^  \([a-zA-Z0-9_-]*\):.*/\1/p')
  if [ -n "$skill" ]; then
    if echo "$line" | grep -q 'enabled: true'; then
      SKILL_ENABLED["$skill"]="true"
    elif echo "$line" | grep -q 'enabled: false'; then
      SKILL_ENABLED["$skill"]="false"
    fi
  fi
done < <(grep -E '^\s{2}[a-zA-Z0-9_-]+:\s*\{' "$AEON_YML" 2>/dev/null || true)

# --- Scan skills directory ---
ALL_SKILLS=()
for d in "${SKILLS_DIR}"/*/; do
  skill=$(basename "$d")
  ALL_SKILLS+=("$skill")
done

# --- Infer output pattern from SKILL.md ---
infer_output_pattern() {
  local skill="$1"
  local skill_md="${SKILLS_DIR}/${skill}/SKILL.md"

  if [ ! -f "$skill_md" ]; then
    echo ""
    return
  fi

  # Look for common output file patterns in the SKILL.md
  local pattern=""

  # Check for articles/{skill}-*.md pattern
  if grep -qE "articles/${skill}" "$skill_md" 2>/dev/null; then
    pattern="articles/${skill}-*.md"
  # Check for articles/ with a different name
  elif grep -qoE 'articles/[a-z0-9_-]+-\$' "$skill_md" 2>/dev/null; then
    pattern=$(grep -oE 'articles/[a-z0-9_-]+' "$skill_md" 2>/dev/null | head -1)
    pattern="${pattern}-*.md"
  # Check for memory/logs pattern
  elif grep -qE 'memory/logs/' "$skill_md" 2>/dev/null && ! grep -qE 'articles/' "$skill_md" 2>/dev/null; then
    pattern="memory/logs/*.md"
  # Check for memory/topics pattern
  elif grep -qE 'memory/topics/' "$skill_md" 2>/dev/null; then
    pattern=$(grep -oE 'memory/topics/[a-z0-9_-]+\.md' "$skill_md" 2>/dev/null | head -1)
    if [ -z "$pattern" ]; then
      pattern="memory/topics/*.md"
    fi
  fi

  echo "$pattern"
}

# --- Classify skills ---
COVERED=()
UNCOVERED_ENABLED=()
UNCOVERED_DISABLED=()
UNCOVERED_UNREGISTERED=()
INFERRED_PATTERNS=()

for skill in "${ALL_SKILLS[@]}"; do
  is_covered=false
  for cs in $COVERED_SKILLS; do
    if [ "$skill" = "$cs" ]; then
      is_covered=true
      break
    fi
  done

  enabled="${SKILL_ENABLED[$skill]:-}"

  if $is_covered; then
    COVERED+=("$skill")
  elif [ "$enabled" = "true" ]; then
    UNCOVERED_ENABLED+=("$skill")
  elif [ "$enabled" = "false" ]; then
    UNCOVERED_DISABLED+=("$skill")
  else
    UNCOVERED_UNREGISTERED+=("$skill")
  fi
done

TOTAL=${#ALL_SKILLS[@]}
COVERED_COUNT=${#COVERED[@]}
UNCOVERED_ENABLED_COUNT=${#UNCOVERED_ENABLED[@]}
UNCOVERED_DISABLED_COUNT=${#UNCOVERED_DISABLED[@]}
UNCOVERED_UNREG_COUNT=${#UNCOVERED_UNREGISTERED[@]}
ENABLED_TOTAL=$(( COVERED_COUNT + UNCOVERED_ENABLED_COUNT ))

if [ "$ENABLED_TOTAL" -gt 0 ]; then
  COVERAGE_PCT=$(( COVERED_COUNT * 100 / ENABLED_TOTAL ))
else
  COVERAGE_PCT=0
fi

# --- JSON output ---
if [ "$FORMAT" = "json" ]; then
  covered_json=$(printf '%s\n' "${COVERED[@]}" | jq -R . | jq -s .)
  uncovered_enabled_json="[]"
  if [ ${#UNCOVERED_ENABLED[@]} -gt 0 ]; then
    uncovered_enabled_json=$(for s in "${UNCOVERED_ENABLED[@]}"; do
      pattern=$(infer_output_pattern "$s")
      jq -n --arg skill "$s" --arg pattern "$pattern" '{skill: $skill, inferred_pattern: $pattern}'
    done | jq -s .)
  fi
  uncovered_disabled_json="[]"
  if [ ${#UNCOVERED_DISABLED[@]} -gt 0 ]; then
    uncovered_disabled_json=$(printf '%s\n' "${UNCOVERED_DISABLED[@]}" | jq -R . | jq -s .)
  fi

  jq -n \
    --argjson total "$TOTAL" \
    --argjson covered "$COVERED_COUNT" \
    --argjson uncovered_enabled "$UNCOVERED_ENABLED_COUNT" \
    --argjson uncovered_disabled "$UNCOVERED_DISABLED_COUNT" \
    --argjson uncovered_unregistered "$UNCOVERED_UNREG_COUNT" \
    --argjson enabled_total "$ENABLED_TOTAL" \
    --argjson coverage_pct "$COVERAGE_PCT" \
    --argjson covered_skills "$covered_json" \
    --argjson uncovered_enabled_skills "$uncovered_enabled_json" \
    --argjson uncovered_disabled_skills "$uncovered_disabled_json" \
    '{
      summary: {
        total_skills: $total,
        covered: $covered,
        uncovered_enabled: $uncovered_enabled,
        uncovered_disabled: $uncovered_disabled,
        uncovered_unregistered: $uncovered_unregistered,
        enabled_total: $enabled_total,
        coverage_pct: $coverage_pct
      },
      covered: $covered_skills,
      uncovered_enabled: $uncovered_enabled_skills,
      uncovered_disabled: $uncovered_disabled_skills
    }'
  exit 0
fi

# --- Generate stub eval entries ---
if [ "$GENERATE_STUBS" = "true" ]; then
  echo "// Stub eval entries for uncovered enabled skills"
  echo "// Paste into skills/skill-evals/evals.json under \"skills\":"
  echo ""
  for skill in "${UNCOVERED_ENABLED[@]}"; do
    pattern=$(infer_output_pattern "$skill")
    if [ -z "$pattern" ]; then
      pattern="memory/logs/*.md"
    fi

    # Determine a reasonable required pattern based on skill name
    req_pattern=$(echo "$skill" | sed 's/-/|/g; s/_/|/g')
    # Also add the original hyphenated form
    req_pattern="${skill}|${req_pattern}"

    cat <<STUB
    "${skill}": {
      "output_pattern": "${pattern}",
      "min_words": 30,
      "required_patterns": ["${req_pattern}"],
      "forbidden_patterns": ["\\\\\\$\\\\{var\\\\}", "\\\\[TODO\\\\]", "PLACEHOLDER"]
    },
STUB
  done
  exit 0
fi

# --- Text output ---
echo "=== Eval Coverage Audit ==="
echo ""
echo "Total skills: ${TOTAL}"
echo "Enabled skills: ${ENABLED_TOTAL}"
echo "Covered by evals.json: ${COVERED_COUNT}"
echo "Uncovered (enabled): ${UNCOVERED_ENABLED_COUNT}"
if [ "$SHOW_ALL" = "true" ]; then
  echo "Uncovered (disabled): ${UNCOVERED_DISABLED_COUNT}"
  echo "Uncovered (not in aeon.yml): ${UNCOVERED_UNREG_COUNT}"
fi
echo ""
echo "Coverage: ${COVERAGE_PCT}% of enabled skills (${COVERED_COUNT}/${ENABLED_TOTAL})"
echo ""

# Show covered skills
echo "--- Covered (${COVERED_COUNT}) ---"
for skill in "${COVERED[@]}"; do
  echo "  ✓ ${skill}"
done
echo ""

# Show uncovered enabled skills with inferred patterns
if [ ${#UNCOVERED_ENABLED[@]} -gt 0 ]; then
  echo "--- Uncovered Enabled (${UNCOVERED_ENABLED_COUNT}) — need eval specs ---"
  for skill in "${UNCOVERED_ENABLED[@]}"; do
    pattern=$(infer_output_pattern "$skill")
    if [ -n "$pattern" ]; then
      echo "  ✗ ${skill}  → inferred: ${pattern}"
    else
      echo "  ✗ ${skill}  → no output pattern detected"
    fi
  done
  echo ""
fi

# Show disabled/unregistered if --all
if [ "$SHOW_ALL" = "true" ]; then
  if [ ${#UNCOVERED_DISABLED[@]} -gt 0 ]; then
    echo "--- Uncovered Disabled (${UNCOVERED_DISABLED_COUNT}) ---"
    for skill in "${UNCOVERED_DISABLED[@]}"; do
      echo "  - ${skill}"
    done
    echo ""
  fi

  if [ ${#UNCOVERED_UNREGISTERED[@]} -gt 0 ]; then
    echo "--- Not in aeon.yml (${UNCOVERED_UNREG_COUNT}) ---"
    for skill in "${UNCOVERED_UNREGISTERED[@]}"; do
      echo "  ? ${skill}"
    done
    echo ""
  fi
fi

# Final recommendation
if [ "$UNCOVERED_ENABLED_COUNT" -gt 0 ]; then
  echo "Run with --stubs to generate eval entries for uncovered enabled skills."
fi
